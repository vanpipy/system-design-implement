# General RAG System Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=general_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Vector Database - Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Cache - Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here

# AI Models
# Embedding Model
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# Primary LLM - DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7

# Fallback LLM - Local
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL_PATH=./models/qwen2.5-1.5b.gguf
LOCAL_LLM_CONTEXT_SIZE=4096

# Security
SECRET_KEY=your_secret_key_here_change_this_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Logging
LOG_FILE=logs/general_rag.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=.pdf,.docx,.txt,.md,.html