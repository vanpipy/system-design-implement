generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// 账户余额表（核心账务数据）
model AccountBalance {
  id            Int      @id @default(autoincrement())
  accountId     String   @db.VarChar(64)  @map("account_id")
  accountType   String   @db.VarChar(20)  @map("account_type")
  currency      String   @db.VarChar(3)
  balance       Decimal  @db.Decimal(20, 4) @default(0.0)
  frozenBalance Decimal  @db.Decimal(20, 4) @map("frozen_balance") @default(0.0)
  totalBalance  Decimal  @db.Decimal(20, 4) @map("total_balance")  @default(0.0)
  minBalance    Decimal  @db.Decimal(20, 4) @default(0.0) @map("min_balance")
  status        String   @db.VarChar(20) @default("ACTIVE")
  allowNegative Boolean  @default(false) @map("allow_negative")
  version       Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  @@map("account_balance")
  @@unique([accountId, accountType, currency], name: "uk_account_balance_account")
  @@index([accountId, accountType, currency], name: "idx_account_balance_account")
  @@index([status], name: "idx_account_balance_status")
}

/// 交易流水表（所有账务变动的原始记录）
model BalanceTransaction {
  id                  Int      @id @default(autoincrement())
  transactionNo       String   @db.VarChar(64)  @map("transaction_no")
  idempotencyKey      String?  @db.VarChar(128) @map("idempotency_key")
  requestId           String   @db.VarChar(64)  @map("request_id")
  batchId             String   @db.VarChar(64)  @map("batch_id")
  accountId           String   @db.VarChar(64)  @map("account_id")
  accountType         String   @db.VarChar(20)  @map("account_type")
  currency            String   @db.VarChar(3)
  transactionType     String   @db.VarChar(30)  @map("transaction_type")
  direction           String   @db.VarChar(4)
  amount              Decimal  @db.Decimal(20, 4)
  beforeBalance       Decimal  @db.Decimal(20, 4) @map("before_balance")
  afterBalance        Decimal  @db.Decimal(20, 4) @map("after_balance")
  oppositeAccount     String?  @db.VarChar(64)   @map("opposite_account")
  oppositeAccountType String?  @db.VarChar(20)   @map("opposite_account_type")
  businessRefNo       String?  @db.VarChar(64)   @map("business_ref_no")
  status              String   @db.VarChar(20)   @default("PENDING")
  errorCode           String?  @db.VarChar(50)   @map("error_code")
  errorMessage        String?  @db.Text          @map("error_message")
  lockType            String   @db.VarChar(20)   @map("lock_type")
  retryCount          Int      @default(0)       @map("retry_count")
  conflictDetected    Boolean  @default(false)   @map("conflict_detected")
  transactionTime     DateTime @default(now())   @map("transaction_time")
  createdAt           DateTime @default(now())   @map("created_at")
  updatedAt           DateTime @updatedAt        @map("updated_at")
  accountingDate      DateTime @default(dbgenerated("CURRENT_DATE")) @map("accounting_date")
  metadata            Json?    @map("metadata")
  clientInfo          Json?    @map("client_info")
  reconciled          Boolean  @default(false)
  reconciledAt        DateTime? @map("reconciled_at")

  @@map("transaction_journal")
  @@unique([transactionNo], name: "uk_transaction_no")
  @@unique([accountId, accountType, currency, idempotencyKey], name: "uk_balance_tx_account_idempotency_key")
  @@index([accountId, accountingDate, createdAt], name: "idx_journal_account_date")
  @@index([accountId, accountType, currency, transactionTime], name: "idx_journal_account_type_currency_time")
  @@index([idempotencyKey], name: "idx_journal_idempotency")
  @@index([status, createdAt], name: "idx_journal_status")
  @@index([conflictDetected, createdAt], name: "idx_journal_conflict")
  @@index([reconciled, accountingDate], name: "idx_journal_reconciliation")
  @@index([businessRefNo], name: "idx_journal_business_ref")
}

/// 余额快照表（记录请求前后余额状态及关联信息）
model BalanceSnapshot {
  id             Int      @id @default(autoincrement())
  accountId      String   @db.VarChar(64)  @map("account_id")
  accountType    String   @db.VarChar(20)  @map("account_type")
  currency       String   @db.VarChar(3)
  requestId      String   @db.VarChar(64)  @map("request_id")
  beforeBalance  Decimal  @db.Decimal(20, 4) @map("before_balance")
  afterBalance   Decimal  @db.Decimal(20, 4) @map("after_balance")
  status         String   @db.VarChar(20)
  accountingDate DateTime @default(dbgenerated("CURRENT_DATE")) @map("accounting_date")
  createdAt      DateTime @default(now()) @map("created_at")
  metadata       Json?    @map("metadata")

  @@map("balance_snapshot")
  @@unique([accountId, accountType, currency, requestId], name: "uk_balance_snapshot_account_request")
  @@index([accountId, accountingDate, createdAt], name: "idx_snapshot_account_date")
  @@index([accountId, accountType, currency, accountingDate], name: "idx_snapshot_account_type_currency_date")
  @@index([requestId], name: "idx_snapshot_request")
  @@index([status, createdAt], name: "idx_snapshot_status")
}

/// 幂等记录表（独立管理幂等键生命周期）
model IdempotencyRecord {
  id             Int      @id @default(autoincrement())
  idempotencyKey String   @db.VarChar(128) @map("idempotency_key")
  requestHash    String   @db.VarChar(64)  @map("request_hash")
  status         String   @db.VarChar(20)
  responseData   Json?    @map("response_data")
  errorInfo      Json?    @map("error_info")
  metadata       Json?    @map("metadata")
  transactionNo  String?  @db.VarChar(64)  @map("transaction_no")
  expiredAt      DateTime @map("expired_at")
  createdAt      DateTime @default(now())  @map("created_at")
  updatedAt      DateTime @updatedAt       @map("updated_at")

  @@map("idempotency_record")
  @@unique([idempotencyKey, requestHash], name: "uk_idempotency_key_hash")
  @@index([expiredAt], name: "idx_idempotency_expired")
  @@index([createdAt], name: "idx_idempotency_cleanup")
}
