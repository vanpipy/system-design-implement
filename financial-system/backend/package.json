{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev:pg": "prisma migrate dev --schema prisma/pg/schema.prisma",
    "prisma:migrate:dev:sqlite": "prisma migrate dev --schema prisma/sqlite/schema.prisma",
    "prisma:studio:pg": "prisma studio --schema prisma/pg/schema.prisma",
    "prisma:studio:sqlite": "prisma studio --schema prisma/sqlite/schema.prisma",
    "dev:sqlite:prepare": "cross-env DATABASE_URL=file:./dev.db prisma migrate dev --schema prisma/sqlite/schema.prisma && cross-env DATABASE_URL=file:./dev.db prisma generate --schema prisma/sqlite/schema.prisma",
    "dev:sqlite": "npm run dev:sqlite:prepare && cross-env DATABASE_URL=file:./dev.db npm run start:dev",
    "verify:quickstart": "bash ./scripts/quickstart.sh",
    "verify:quickstart:ps1": "powershell -ExecutionPolicy Bypass -File ./scripts/quickstart.ps1",
    "verify:quickstart:bat": "cmd /c scripts\\quickstart.bat",
    "dev:pg:prepare": "prisma migrate dev --schema prisma/pg/schema.prisma && prisma generate --schema prisma/pg/schema.prisma",
    "dev:pg": "npm run dev:pg:prepare && npm run start:dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^7.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "decimal.js": "^10.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "test/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^root/generated/prisma/client$": "<rootDir>/test/prisma-client.stub.ts"
    }
  },
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "src/prisma/prisma.service.ts"
        ],
        "rules": {
          "@typescript-eslint/no-require-imports": "off",
          "@typescript-eslint/no-unsafe-assignment": "off",
          "@typescript-eslint/no-unsafe-return": "off",
          "@typescript-eslint/no-unsafe-member-access": "off",
          "@typescript-eslint/no-unsafe-call": "off"
        }
      }
    ]
  }
}
